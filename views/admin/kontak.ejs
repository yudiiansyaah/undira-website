<%- include('partials/sidebar') %>

<div class="page-actions">
  <h2>Pesan Masuk</h2>
  <span class="badge-count"><%= data.length %> pesan</span>
</div>

<div class="filter-bar">
  <form method="GET" class="filter-form">
    <select name="status">
      <option value="">Semua Status</option>
      <option value="belum_dibaca" <%= filter.status === 'belum_dibaca' ? 'selected' : '' %>>Belum Dibaca</option>
      <option value="sudah_dibaca" <%= filter.status === 'sudah_dibaca' ? 'selected' : '' %>>Sudah Dibaca</option>
    </select>
    <button type="submit" class="btn-filter">Filter</button>
    <a href="/admin/kontak" class="btn-reset">Reset</a>
  </form>
</div>

<div class="card">
  <div class="table-wrap">
    <table class="data-table">
      <thead>
        <tr><th>No</th><th>Nama</th><th>Email</th><th>Subjek</th><th>Status</th><th>Tanggal</th><th>Aksi</th></tr>
      </thead>
      <tbody>
        <% if (data.length === 0) { %><tr><td colspan="7" class="text-center text-muted">Tidak ada pesan</td></tr><% } %>
        <% data.forEach((k, i) => { %>
        <tr class="<%= k.status === 'belum_dibaca' ? 'row-unread' : '' %>">
          <td><%= i + 1 %></td>
          <td><b><%= k.nama %></b></td>
          <td><%= k.email %></td>
          <td><%= k.subjek %></td>
          <td><span class="badge badge-<%= k.status === 'belum_dibaca' ? 'pending' : 'diterima' %>"><%= k.status === 'belum_dibaca' ? 'Baru' : 'Dibaca' %></span></td>
          <td><%= new Date(k.created_at).toLocaleDateString('id-ID') %></td>
          <td>
            <a href="/admin/kontak/<%= k.id %>" class="btn-table">Baca</a>
            <form method="POST" action="/admin/kontak/<%= k.id %>/hapus" style="display:inline" onsubmit="return confirm('Hapus pesan ini?')">
              <button type="submit" class="btn-table btn-table-danger">Hapus</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('partials/sidebar-end') %>
