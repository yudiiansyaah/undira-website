<%- include('partials/sidebar') %>

<div class="page-actions">
  <a href="/admin/kampus" class="btn-back">&larr; Kembali</a>
  <h2><%= item ? 'Edit Kampus' : 'Tambah Kampus Baru' %></h2>
</div>

<% if (error && error.length) { %><div class="alert alert-error"><%= error %></div><% } %>

<div class="card">
  <form method="POST" action="<%= item ? '/admin/kampus/' + item.id + '/edit' : '/admin/kampus/buat' %>">
    <div class="form-row-2">
      <div class="form-group">
        <label>ID Kampus (Slug) <span class="required">*</span></label>
        <input type="text" name="id" value="<%= item ? item.id : '' %>" placeholder="contoh: tanjung-duren" <%= item ? 'readonly' : 'required' %>>
      </div>
      <div class="form-group">
        <label>Nama Kampus <span class="required">*</span></label>
        <input type="text" name="nama" value="<%= item ? item.nama : '' %>" placeholder="Nama Kampus" required>
      </div>
    </div>

    <div class="form-group">
      <label>Alamat Lengkap</label>
      <input type="text" name="alamat" value="<%= item ? item.alamat : '' %>" placeholder="Jl. ...">
    </div>

    <div class="form-row-2">
      <div class="form-group">
        <label>Telepon</label>
        <input type="text" name="telepon" value="<%= item ? item.telepon : '' %>" placeholder="(021) ...">
      </div>
      <div class="form-group">
        <label>Email Kampus</label>
        <input type="email" name="email" value="<%= item ? item.email : '' %>" placeholder="info.kampus@undira.ac.id">
      </div>
    </div>

    <div class="form-group">
      <label>Google Maps Link</label>
      <input type="url" name="maps" value="<%= item ? item.maps : '' %>" placeholder="https://maps.google.com/...">
    </div>

    <div class="form-group">
      <label>Keterangan Singkat</label>
      <input type="text" name="keterangan" value="<%= item ? item.keterangan : '' %>" placeholder="Contoh: Kampus Utama">
    </div>

    <div class="form-group">
      <label>Fasilitas (Satu per baris)</label>
      <textarea name="fasilitas" rows="6" placeholder="Fasilitas 1&#10;Fasilitas 2&#10;Fasilitas 3"><%= item ? item.fasilitas : '' %></textarea>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn-primary-full"><%= item ? 'Simpan Perubahan' : 'Tambah Kampus' %></button>
    </div>
  </form>
</div>

<%- include('partials/sidebar-end') %>
