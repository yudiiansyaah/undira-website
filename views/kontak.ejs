<%- include('partials/header') %>

<div class="page-hero page-hero-sm">
  <div class="container">
    <div class="breadcrumb"><a href="/">Beranda</a> / Kontak</div>
    <h1>Hubungi Kami</h1>
    <p>Kami siap membantu pertanyaan Anda</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="kontak-grid">
      <div class="kontak-info">
        <h2>Informasi Kontak</h2>
        <p>Silakan hubungi kami melalui salah satu cara berikut atau kunjungi langsung kampus kami.</p>

        <% kampus.forEach(k => { %>
        <div class="kontak-kampus-card">
          <h3><%= k.nama %></h3>
          <div class="kontak-detail">
            <p>&#128205; <%= k.alamat %></p>
            <p>&#128222; <%= k.telepon %></p>
            <p>&#9993;&#65039; <%= k.email %></p>
          </div>
        </div>
        <% }) %>

        <div class="kontak-sosmed">
          <h3>Media Sosial</h3>
          <div class="sosmed-links">
            <a href="#" class="sosmed-item">Facebook - @undira.official</a>
            <a href="#" class="sosmed-item">Instagram - @undira_id</a>
            <a href="#" class="sosmed-item">YouTube - Universitas Dian Nusantara</a>
            <a href="#" class="sosmed-item">LinkedIn - Universitas Dian Nusantara</a>
          </div>
        </div>
      </div>

      <div class="kontak-form-wrap">
        <div class="kontak-form-card">
          <h2>Kirim Pesan</h2>
          <form class="kontak-form" id="kontakForm">
            <div class="form-row">
              <div class="form-group">
                <label>Nama Lengkap</label>
                <input type="text" name="nama" placeholder="Nama Anda" required>
              </div>
              <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="email@example.com" required>
              </div>
            </div>
            <div class="form-group">
              <label>Nomor Telepon</label>
              <input type="tel" name="telepon" placeholder="08xx-xxxx-xxxx">
            </div>
            <div class="form-group">
              <label>Subjek</label>
              <select name="subjek">
                <option value="Informasi Penerimaan Mahasiswa Baru">Informasi Penerimaan Mahasiswa Baru</option>
                <option value="Informasi Program Studi">Informasi Program Studi</option>
                <option value="Informasi Beasiswa">Informasi Beasiswa</option>
                <option value="Kerjasama Institusi">Kerjasama Institusi</option>
                <option value="Lainnya">Lainnya</option>
              </select>
            </div>
            <div class="form-group">
              <label>Pesan</label>
              <textarea name="pesan" rows="5" placeholder="Tuliskan pesan Anda di sini..." required></textarea>
            </div>
            <div id="kontakMsg" style="display:none"></div>
            <button type="submit" class="btn btn-primary btn-block">Kirim Pesan</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
